{
  "name": "@learnus-notifier/scheduler",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "check": "biome check src/",
    "test:crawl": "node --env-file=../../.env --import tsx/esm scripts/test-crawl.ts",
    "inspect-login": "node --import tsx/esm scripts/inspect-login.ts",
    "inspect-assignments": "node --env-file=../../.env --import tsx/esm scripts/inspect-assignments.ts",
    "inspect-lectures": "node --env-file=../../.env --import tsx/esm scripts/inspect-lectures.ts",
    "inspect-vod-page": "node --env-file=../../.env --import tsx/esm scripts/inspect-vod-page.ts"
  },
  "dependencies": {
    "@learnus-notifier/db": "workspace:*",
    "@learnus-notifier/scraper": "workspace:*",
    "@learnus-notifier/telegram": "workspace:*",
    "dotenv": "^16.0.0",
    "node-cron": "^3.0.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.0",
    "playwright": "^1.58.0",
    "typescript": "^5.7.0"
  }
}
