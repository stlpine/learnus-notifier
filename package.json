{
  "name": "learnus-notifier",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "turbo test",
    "test:crawl": "pnpm --filter @learnus-notifier/scheduler run test:crawl"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "^25.0.0",
    "dotenv": "^16.0.0",
    "tsx": "^4.21.0",
    "turbo": "2.8.16",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1"
}
